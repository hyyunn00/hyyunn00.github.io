---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TopBar from '../TopBar.astro';
import Footer from '../Footer.astro';
import WorkGrid from '../WorkGrid.astro';
import { t, type Locale } from '../../i18n/ui';

interface Props {
  lang: Locale;
  altHref: string;
}

const { lang, altHref } = Astro.props;
const dict = t(lang);
const folder = lang === 'zh-TW' ? 'zh' : 'en';

const items = await getCollection('work', (entry) => entry.id.startsWith(`${folder}/`) && !entry.data.draft);
items.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout lang={lang} title={`${dict.nav.workSub} · ${dict.siteTitle}`}>
  <TopBar lang={lang} active="work" altHref={altHref} />
  <main id="main" class="page" data-pagefind-body>
    <div class="page-head">
      <h1 class="serif">{dict.nav.workSub} <span class="en">{dict.nav.work}</span></h1>
    </div>
    <div style="padding-top: clamp(24px, 4vw, 36px);">
      <WorkGrid items={items} lang={lang} />
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
