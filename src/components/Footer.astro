---
import { t, type Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const dict = t(lang);
const year = new Date().getFullYear();
---

<footer>
  <span>© {year} {dict.siteTitle} · {dict.siteSubtitle}</span>
  <span class="social">
    <a href="https://www.instagram.com/hyyunn.n/" target="_blank" rel="noopener noreferrer">Instagram</a>
    <a href="https://www.behance.net/hyyunn" target="_blank" rel="noopener noreferrer">Behance</a>
    <a href="mailto:ianne1684@gmail.com">Email</a>
  </span>
</footer>
