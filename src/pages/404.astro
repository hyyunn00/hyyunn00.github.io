---
import Layout from '../layouts/Layout.astro';
---

<Layout lang="zh-TW" title="404 · 黃苡恩">
  <main
    style="min-height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; text-align: center; padding: 20px;"
  >
    <span class="mono" style="font-size: 0.8rem; color: var(--ink-faint);">404</span>
    <h1 class="serif" style="font-size: 1.6rem; margin: 0;">這一頁不見了 · Page not found</h1>
    <a href="/" style="color: var(--accent-strong); border-bottom: 1px solid var(--accent);">回到首頁 · Back home</a>
  </main>
</Layout>
