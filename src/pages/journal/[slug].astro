---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import JournalDetailPage from '../../components/views/JournalDetailPage.astro';

export async function getStaticPaths() {
  const entries = await getCollection('journal', (entry) => entry.id.startsWith('zh/') && !entry.data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.split('/').slice(1).join('/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<JournalDetailPage
  entry={entry}
  lang="zh-TW"
  altHref={getRelativeLocaleUrl('en', `/journal/${Astro.params.slug}/`)}
/>
